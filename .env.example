# --- Bot Identity ---
# Discord Bot Token
TOKEN=your_bot_token_here

# --- Security ---
# Comma-separated list of User IDs for developers/owners
OWNERS=1378603697755521044

# --- Environment ---
# 'development' or 'production'
ENV=production

# --- Network ---
# Optional: HTTP/HTTPS proxy URL
PROXY=

# --- Maintenance ---
# Number of days to keep forensic logs before auto-deletion
LOG_RETENTION_DAYS=7
